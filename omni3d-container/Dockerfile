# ── system dependencies ──────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    binutils \
    supervisor \
    libz-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── build and install omnode ─────────────────────────────────────────
COPY OMNI3D_omnode/ /build/OMNI3D_omnode/
COPY omni3d-container/requirements.txt /tmp/requirements.txt
RUN SETUPTOOLS_SCM_PRETEND_VERSION=0.0.1 pip install --no-cache-dir /build/OMNI3D_omnode/ && \
    pip install --no-cache-dir -r /tmp/requirements.txt && \
    pip install --no-cache-dir pyinstaller

# ── build service binaries ───────────────────────────────────────────
RUN mkdir -p /app
WORKDIR /build

COPY OMNI3D_MMS/src/ /build/OMNI3D_MMS/
RUN pyinstaller /build/OMNI3D_MMS/mms.py --onedir -y \
    --collect-all omnode \
    --collect-all fastapi \
    --collect-all uvicorn \
    && mv /build/dist/mms /app/mms

COPY OMNI3D_Template/src/ /build/OMNI3D_Template/
RUN pyinstaller /build/OMNI3D_Template/template.py --onedir -y \
    --collect-all omnode \
    --collect-all fastapi \
    --collect-all uvicorn \
    && mv /build/dist/template /app/template

COPY OMNI3D_Work_Time_Counter/src/ /build/OMNI3D_Work_Time_Counter/
RUN pyinstaller /build/OMNI3D_Work_Time_Counter/WorkTimeCounter.py --onedir -y \
    --collect-all omnode \
    --collect-all fastapi \
    --collect-all uvicorn \
    && mv /build/dist/WorkTimeCounter /app/WorkTimeCounter

# ── supervisord config ───────────────────────────────────────────────
